class Solution {
    public int searchInsert(int[] nums, int target) {
        int result = 0;
        int i = 0;
        int j = i+1;
        while(i < nums.length) {
            if(nums[i] < target) {
                if(i == nums.length - 1) {
                    return i + 1;
                }
                for(j = i+1; j < nums.length; j++) {
                    if(nums[j] < target) {
                        if(j == nums.length - 1) {
                            result = j + 1;
                            return result;
                        }
                        continue;
                    }
                    else {
                        result = j;
                        return result;
                    }
                }
            }
            else if(nums[i] == target) {
                result = i;
                return result;
            }
            else if(nums[i] > target) {
                result = 0;
                return result;
            }
            i++;
        }
        if(i == nums.length - 1 && result == 0) {
            result = nums.length;
        }
        return result;
    }
}