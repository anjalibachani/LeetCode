class Solution {
    public void merge(int[] nums1, int m, int[] nums2, int n) {
        int[] result = new int[m+n];
        int k = 0;
        for(int i = 0; i <= m;) {
            for(int j = 0; j <=n;) {
                System.out.println("i=" +i +"j="+j);
                
                if(nums1[i] < nums2[j])  {
                    System.out.println("111nums1i=" + nums1[i] + "nums2j"+nums2[j]);
                    result[k] = nums1[i];
                    k++;
                    i++;
                }
                //System.out.println("222nums1i=" +nums1[i] + "nums2j"+nums2[j]);
                else {
                    result[k] = nums2[j];

                    
                    k++;
                    j++;
                }
                System.out.println("3333nums1i=" +nums1[i] + "nums2j"+nums2[j]);
                System.out.println("k = " + result[k]);
            }
        }
    }
}