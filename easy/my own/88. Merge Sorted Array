class Solution {
    public void merge(int[] nums1, int m, int[] nums2, int n) {
        int midx = m-1;
        int nidx = n-1;
        int pointer = m+n-1;

        while(nidx >= 0 && midx >=0) {
            if(nums1[midx] < nums2[nidx]) {
                nums1[pointer] = nums2[nidx];
                nidx--;
                pointer--;
            }
            else{
                nums1[pointer] = nums1[midx];
                pointer--;
                midx--;
            }
        }
        if(midx < 0) {
            while(nidx >= 0) {
                nums1[pointer] = nums2[nidx];
                nidx--;
                pointer--;
            }
        }
    }
}